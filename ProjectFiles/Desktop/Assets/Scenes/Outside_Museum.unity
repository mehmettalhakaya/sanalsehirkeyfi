--- !u!1001 &6605005334359356566
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 1985218972702153688, guid: 665cc4af457cf3340bdc625c6b87a9a3, type: 3}
      propertyPath: description
      value: "Louvre'un kuzey kanad\u0131 olan Richelieu Kanad\u0131, m\xFCzenin
        g\xF6rkemli Napolyon III daireleri ve geni\u015F dekoratif sanat koleksiyonlar\u0131yla
        \xF6ne \xE7\u0131kar. Ad\u0131n\u0131 Kardinal Richelieu'den al\u0131r.\n\n\xD6nemli
        eserler:\n\nHammurabi Kanunlar\u0131 (M\xD6 1754)\nOturan Yazman (M\xD6 2600-2350,
        Antik M\u0131s\u0131r)\nMarly Atlar\u0131 (Guillaume Coustou, 1745)\nNapolyon
        III Daireleri\nAssur ve Mezopotamya kabartmalar\u0131\n\nFrans\u0131z dekoratif
        sanatlar\u0131, Mezopotamya uygarl\u0131klar\u0131, Antik Yak\u0131n Do\u011Fu
        eserleri ve Napolyon d\xF6nemi ihti\u015Fam\u0131n\u0131n merkezi."
      objectReference: {fileID: 0}
    - target: {fileID: 1985218972702153688, guid: 665cc4af457cf3340bdc625c6b87a9a3, type: 3}
      propertyPath: objectTitle
      value: "Richelieu Kanad\u0131"
      objectReference: {fileID: 0}
