--- !u!1001 &1087009044
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 1985218972702153688, guid: 665cc4af457cf3340bdc625c6b87a9a3, type: 3}
      propertyPath: description
      value: "Louvre'un do\u011Fu kanad\u0131 olan Sully Pavyonu, m\xFCzenin en eski
        b\xF6l\xFCm\xFCd\xFCr. 1546'da Pierre Lescot taraf\u0131ndan in\u015Fa edilmeye
        ba\u015Flanm\u0131\u015F, eski Louvre \u015Eatosu'nun temelleri burada bulunur.\r\n\r\nBodrum
        kat\u0131nda, 12. y\xFCzy\u0131lda II. Philippe Augustus taraf\u0131ndan
        yapt\u0131r\u0131lan orta\xE7a\u011F kalesinin kal\u0131nt\u0131lar\u0131n\u0131
        gezebilirsiniz.\r\n\r\nKoleksiyonlar:\r\n- M\u0131s\u0131r Antikalar\u0131
        (mumyalar, lahitler, hiyeroglifler)\r\n- Yak\u0131n Do\u011Fu Antikalar\u0131
        (Hammurabi Yasas\u0131, Asur sanat\u0131)\r\n- Antik Yunan, Etr\xFCsk ve
        Roma sanat\u0131\r\n- 17.-18. y\xFCzy\u0131l Frans\u0131z resmi\r\n\r\nPavyonun
        ad\u0131 Henri IV'\xFCn ba\u015Fbakan\u0131 Maximilien de B\xE9thune, Duc
        de Sully'den gelir."
      objectReference: {fileID: 0}
    - target: {fileID: 1985218972702153688, guid: 665cc4af457cf3340bdc625c6b87a9a3, type: 3}
      propertyPath: objectTitle
      value: "Sully Kanad\u0131"
