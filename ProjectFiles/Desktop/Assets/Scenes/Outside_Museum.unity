--- !u!1001 &201392342
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 1985218972702153688, guid: 665cc4af457cf3340bdc625c6b87a9a3, type: 3}
      propertyPath: description
      value: "Louvre'un g\xFCney kanad\u0131 olan Denon Pavyonu, m\xFCzenin en \xFCnl\xFC
        eserlerine ev sahipli\u011Fi yapar. Ad\u0131n\u0131 Napolyon'un ilk m\xFCze
        direkt\xF6r\xFC Dominique-Vivant Denon'dan al\u0131r.\r\n\r\n\xD6nemli eserler:\r\n-
        Mona Lisa (Leonardo da Vinci, 1503-1519)\r\n- Ven\xFCs de Milo (M\xD6 130-100,
        antik Yunan)\r\n- Samothrakeli Nike (M\xD6 200-190)\r\n- \xD6zg\xFCrl\xFC\u011F\xFC
        Y\xF6nlendiren Halk (Delacroix, 1830)\r\n- Medusa'n\u0131n Sal\u0131 (G\xE9ricault,
        1819)\r\n\r\n\u0130talyan R\xF6nesans resmi, antik Yunan ve Roma heykelleri
        ile 19. y\xFCzy\u0131l Frans\u0131z resminin merkezi."
      objectReference: {fileID: 0}
    - target: {fileID: 1985218972702153688, guid: 665cc4af457cf3340bdc625c6b87a9a3, type: 3}
      propertyPath: objectTitle
      value: "Denon Kanad\u0131"
      objectReference: {fileID: 0}
