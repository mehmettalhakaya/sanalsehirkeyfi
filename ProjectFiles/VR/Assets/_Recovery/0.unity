MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 77225237}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e50f79245aa9f924b95c8133ed43f8dc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InteractableObject
  title: Denon Pavyonu
  description: "Louvre'un g\xFCney kanad\u0131 olan Denon Pavyonu, m\xFCzenin en
    \xFCnl\xFC eserlerine ev sahipli\u011Fi yapar. Ad\u0131n\u0131 Napolyon'un ilk
    m\xFCze direkt\xF6r\xFC Dominique-Vivant Denon'dan al\u0131r.\r\n\r\n\xD6nemli
    eserler:\r\n- Mona Lisa (Leonardo da Vinci, 1503-1519)\r\n- Ven\xFCs de Milo
    (M\xD6 130-100, antik Yunan)\r\n- Samothrakeli Nike (M\xD6 200-190)\r\n- \xD6zg\xFCrl\xFC\u011F\xFC
    Y\xF6nlendiren Halk (Delacroix, 1830)\r\n- Medusa'n\u0131n Sal\u0131 (G\xE9ricault,
    1819)\r\n\r\n\u0130talyan R\xF6nesans resmi, antik Yunan ve Roma heykelleri ile
    19. y\xFCzy\u0131l Frans\u0131z resminin merkezi."
  imageOptional: {fileID: 0}
  highlightOnHover: 1
  highlightColor: {r: 1, g: 0.85, b: 0.4, a: 1}
