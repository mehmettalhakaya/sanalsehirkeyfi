  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 94c46ecd48d7cdb4786744f4644a0188, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InfoInteract
  objectTitle: "J\xFClich'in Zapt\u0131 \u2013 Rubens"
  description: "Peter Paul Rubens, J\xFClich'in Zapt\u0131 (La Prise de Juliers),
    1622\u201325. Tuval \xFCzerine ya\u011Fl\u0131boya. Galerie M\xE9dicis, Louvre.
    Marie de' Medici Serisi'nden olan bu tabloda Krali\xE7e, mi\u011Fferi ve z\u0131rh\u0131yla
    beyaz at \xFCst\xFCnde Amazon krali\xE7esi gibi resmedilir; 1610'da Frans\u0131z
    ordular\u0131n\u0131n J\xFClich kalesini ele ge\xE7irmesini kutlamak i\xE7in
    zaferi simgeleyen kanatl\u0131 fig\xFCr ba\u015F\u0131na defne \xE7elengi koyarken,
    arkada sava\u015Fan ordular ve teslim olan kale g\xF6r\xFCn\xFCr."
