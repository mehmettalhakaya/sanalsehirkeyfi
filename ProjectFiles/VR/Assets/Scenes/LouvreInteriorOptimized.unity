  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 94c46ecd48d7cdb4786744f4644a0188, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InfoInteract
  objectTitle: "Francesco I de' Medici Portresi \u2013 Rubens"
  description: "Peter Paul Rubens (ve at\xF6lyesi), Francesco I de' Medici, Toskana
    B\xFCy\xFCk D\xFCk\xFC, 1622\u201325. Tuval \xFCzerine ya\u011Fl\u0131boya. Galerie
    M\xE9dicis, Louvre. Marie de' Medici Serisi'ne e\u015Flik eden iki ebeveyn portresinden
    biridir. Burada Krali\xE7e'nin babas\u0131, Toskana B\xFCy\xFCk D\xFCk\xFC Francesco
    I de' Medici (1541\u20131587), k\xFCrk astarl\u0131 asalet k\u0131yafetleri,
    a\u011F\u0131r alt\u0131n zinciri ve g\xF6\u011Fs\xFCndeki Aziz Stephen Ni\u015Fan\u0131
    ile resmi t\xF6ren duru\u015Funda tasvir edilir. Francesco, Marie 1575'te Floransa'da
    do\u011Fdu\u011Funda Toskana'y\u0131 y\xF6neten Medici hanedan\u0131n\u0131n
    ba\u015F\u0131yd\u0131."
