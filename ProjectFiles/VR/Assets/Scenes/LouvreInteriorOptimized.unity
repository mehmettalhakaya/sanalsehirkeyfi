  m_Script: {fileID: 11500000, guid: 94c46ecd48d7cdb4786744f4644a0188, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InfoInteract
  objectTitle: "Marie de' Medici'nin Saint-Denis'te Ta\xE7 Giymesi \u2013 Rubens"
  description: "Peter Paul Rubens, Marie de' Medici'nin Saint-Denis'te Ta\xE7 Giymesi,
    1622\u201325. Tuval \xFCzerine ya\u011Fl\u0131boya. Galerie M\xE9dicis, Louvre.
    Marie de' Medici Serisi'nin en b\xFCy\xFCk tablolar\u0131ndan biridir; 13 May\u0131s
    1610'da Saint-Denis Bazilikas\u0131'nda kardinaller e\u015Fli\u011Finde ger\xE7ekle\u015Ftirilen
    ta\xE7 giyme t\xF6renini resmeder. T\xF6ren IV. Henri'nin Ravaillac taraf\u0131ndan
    suikaste kurban gitmesinden yaln\u0131zca bir g\xFCn \xF6nce yap\u0131lm\u0131\u015F
    ve Marie'nin Fransa Krali\xE7esi olarak resmi konumunu peki\u015Ftirmi\u015Ftir."
