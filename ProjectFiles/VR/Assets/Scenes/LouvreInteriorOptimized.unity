  m_Script: {fileID: 11500000, guid: 94c46ecd48d7cdb4786744f4644a0188, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InfoInteract
  objectTitle: "Hakikatin ve Adaletin \u0130nat\xE7\u0131l\u0131\u011Fa Kar\u015F\u0131
    Zaferi \u2013 Rubens"
  description: "Peter Paul Rubens, Hakikatin ve Adaletin \u0130syana Kar\u015F\u0131
    Zaferi, 1622\u201325. Tuval \xFCzerine ya\u011Fl\u0131boya. Galerie M\xE9dicis,
    Louvre. Marie de' Medici Serisi'nden olan bu alegorik tabloda Krali\xE7e'nin
    d\xF6neminde ya\u015Fanan i\xE7 \xE7eki\u015Fme ve d\xFC\u015Fmanl\u0131klar,
    ejderha ve y\u0131lan fig\xFCrleriyle sembolize edilirken \xFCst k\u0131s\u0131mda
    Apollon ve di\u011Fer ilahi fig\xFCrler bu k\xF6t\xFCl\xFCkleri oklar\u0131 ve
    \u015Fim\u015Fekleriyle alt eder. Yerde k\u0131vranan y\u0131lanlar Nifak (Discordia),
    \u0130syan ve Sapk\u0131nl\u0131\u011F\u0131 temsil ederken \xFCstteki \u0131\u015F\u0131kl\u0131
    sahne Tanr\u0131sal d\xFCzenin ve Kraliyet otoritesinin nihai zaferini y\xFCceltir."
