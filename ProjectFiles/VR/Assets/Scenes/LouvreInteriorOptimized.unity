  m_Script: {fileID: 11500000, guid: 94c46ecd48d7cdb4786744f4644a0188, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InfoInteract
  objectTitle: "Prenseslerin \u0130spanya S\u0131n\u0131r\u0131nda M\xFCbadelesi
    \u2013 Rubens"
  description: "Peter Paul Rubens, Prenseslerin \u0130spanya S\u0131n\u0131r\u0131nda
    M\xFCbadelesi (L'\xC9change des Princesses), 1622\u201325. Tuval \xFCzerine ya\u011Fl\u0131boya.
    Galerie M\xE9dicis, Louvre. Marie de' Medici Serisi'nden olan bu tabloda 9 Kas\u0131m
    1615'te Bidassoa Nehri'nde ger\xE7ekle\u015Ftirilen \xE7ifte m\xFCbadele resmedilir;
    Marie'nin k\u0131z\u0131 Prenses Elizabeth gelecekteki \u0130spanya Kral\u0131
    IV. Felipe ile evlenmek \xFCzere g\xFCneye, Avusturyal\u0131 Anna ise XIII. Louis
    ile evlenmek \xFCzere kuzeye ge\xE7er. Alttaki uzanan fig\xFCr ise iki krall\u0131k
    aras\u0131ndaki s\u0131n\u0131r\u0131 olu\u015Fturan Bidassoa nehir tanr\u0131s\u0131n\u0131
    simgeler."
