  m_Script: {fileID: 11500000, guid: 94c46ecd48d7cdb4786744f4644a0188, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InfoInteract
  objectTitle: "Krali\xE7enin O\u011Fluyla Uzla\u015Fmas\u0131 \u2013 Rubens"
  description: "Peter Paul Rubens, Krali\xE7enin O\u011Fluyla Uzla\u015Fmas\u0131
    (La R\xE9conciliation de la Reine et de son Fils), 1622\u201325. Tuval \xFCzerine
    ya\u011Fl\u0131boya. Galerie M\xE9dicis, Louvre. Marie de' Medici Serisi'nden
    olan bu tabloda, o\u011Flu XIII. Louis ile uzun s\xFCredir devam eden siyasi
    gerilim sonunda 1620'de Angers'de imzalanan bar\u0131\u015F antla\u015Fmas\u0131yla
    son bulur; Krali\xE7e ve o\u011Flu aras\u0131ndaki uzla\u015Fma alegorik fig\xFCrler
    ve yukar\u0131da bar\u0131\u015F\u0131 simgeleyen kanatl\u0131 melek e\u015Fli\u011Finde
    tasvir edilirken askerler silahlar\u0131n\u0131 indirir."
