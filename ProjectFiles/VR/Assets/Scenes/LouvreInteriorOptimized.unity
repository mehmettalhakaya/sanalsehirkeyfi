  m_Script: {fileID: 11500000, guid: 94c46ecd48d7cdb4786744f4644a0188, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InfoInteract
  objectTitle: "Bellona Olarak Marie de' Medici \u2013 Rubens"
  description: "Peter Paul Rubens, Bellona / Minerva Olarak Marie de' Medici, 1622\u201325.
    Tuval \xFCzerine ya\u011Fl\u0131boya. Galerie M\xE9dicis, Louvre. Marie de' Medici
    Serisi'nden olan bu alegorik portrede Krali\xE7e, ba\u015F\u0131nda mi\u011Fferi
    ve elinde defne dal\u0131/asas\u0131yla sava\u015F tanr\u0131\xE7as\u0131 Bellona
    (ya da bilgelik tanr\u0131\xE7as\u0131 Minerva) suretinde tasvir edilir. Ayaklar\u0131n\u0131n
    dibine b\u0131rak\u0131lm\u0131\u015F z\u0131rh, mi\u011Ffer ve silahlar Fransa'ya
    getirdi\u011Fi bar\u0131\u015F\u0131 simgelerken yukar\u0131daki melekler defne
    \xE7elengiyle onu ta\xE7land\u0131r\u0131r; sol taraftaki kanatl\u0131 k\xFC\xE7\xFCk
    fig\xFCr ise Zafer'i (Victoria) temsil eder."
