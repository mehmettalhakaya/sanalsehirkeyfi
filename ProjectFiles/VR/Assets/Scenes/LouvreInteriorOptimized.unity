  m_Script: {fileID: 11500000, guid: 94c46ecd48d7cdb4786744f4644a0188, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InfoInteract
  objectTitle: "Hakikatin Zaferi \u2013 Rubens"
  description: "Peter Paul Rubens, Hakikatin Zaferi / Zaman\u0131n Hakikati A\xE7\u0131\u011Fa
    \xC7\u0131karmas\u0131 (Le Triomphe de la V\xE9rit\xE9), 1622\u201325. Tuval
    \xFCzerine ya\u011Fl\u0131boya. Galerie M\xE9dicis, Louvre. Marie de' Medici
    Serisi'nin son ve sonu\xE7 niteli\u011Findeki tablosudur. Burada Krali\xE7e,
    Zaman Tanr\u0131s\u0131 Saturn ile Hakikat fig\xFCr\xFC taraf\u0131ndan kald\u0131r\u0131larak
    \xFCn\xFCn\xFCn ve masumiyetinin t\xFCm d\xFCnyaya ilan edili\u015Fi resmedilir;
    yere at\u0131lm\u0131\u015F mi\u011Ffer ve silahlar, sava\u015F d\xF6neminin
    sona erdi\u011Fini ve o\u011Flu XIII. Louis ile ger\xE7ek bir uzla\u015Fmaya
    var\u0131ld\u0131\u011F\u0131n\u0131 simgeler."
