  m_Script: {fileID: 11500000, guid: 94c46ecd48d7cdb4786744f4644a0188, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InfoInteract
  objectTitle: "Marie de' Medici'nin Portresinin Henri IV'e Sunulmas\u0131 \u2013
    Rubens"
  description: "Peter Paul Rubens, Marie de' Medici'nin Portresinin Henri IV'e Sunulmas\u0131,
    1622\u201325. Tuval \xFCzerine ya\u011Fl\u0131boya. Galerie M\xE9dicis, Louvre.
    Marie de' Medici Serisi'nden olan bu tabloda, Hymen ve Cupido (A\u015Fk Tanr\u0131s\u0131),
    Fransa Kral\u0131 IV. Henri'ye m\xFCstakbel e\u015Fi Marie de' Medici'nin portresini
    takdim ederken J\xFCpiter ve Juno bulutlar\u0131n \xFCzerinden bu birle\u015Fmeyi
    onaylar."
