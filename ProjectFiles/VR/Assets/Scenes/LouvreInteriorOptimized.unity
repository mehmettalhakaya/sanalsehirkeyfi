  m_Script: {fileID: 11500000, guid: 94c46ecd48d7cdb4786744f4644a0188, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InfoInteract
  objectTitle: "Zaman\u0131n Hakikati A\xE7\u0131\u011Fa \xC7\u0131karmas\u0131 \u2013
    Rubens"
  description: "Peter Paul Rubens, Zaman\u0131n Hakikati A\xE7\u0131\u011Fa \xC7\u0131karmas\u0131
    (Le Temps d\xE9couvre la V\xE9rit\xE9), 1622\u201325. Tuval \xFCzerine ya\u011Fl\u0131boya.
    Galerie M\xE9dicis, Louvre. Marie de' Medici Serisi'nin son tablosudur. Burada
    kanatl\u0131 ya\u015Fl\u0131 fig\xFCr Zaman (Kronos/Sat\xFCrn), \xE7\u0131plak
    gen\xE7 kad\u0131n olarak resmedilen Hakikat'i yukar\u0131 do\u011Fru kald\u0131rarak
    g\xF6\u011Fe y\xFCkseltir. \xDCst k\u0131s\u0131mda Marie de' Medici ile o\u011Flu
    XIII. Louis'in alegorik birle\u015Fmesi defne \xE7elengiyle ta\xE7land\u0131r\u0131l\u0131r;
    t\xFCm seri, zamanla iftiralar\u0131n yok olup ger\xE7ek erdemlerin ortaya \xE7\u0131kaca\u011F\u0131
    mesaj\u0131yla son bulur."
